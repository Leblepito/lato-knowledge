# Lato Telegram Bot — Railway image (repo kökünden build edilir)
# İçerik: Python + git + Node/claude CLI (abonelik ile ücretsiz Sonnet 5) + tüm bilgi bankası
FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates gnupg && \
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    npm install -g @anthropic-ai/claude-code && \
    rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir "httpx>=0.27" tzdata "openai>=1.0"
# openai paketi: ceviri-sistemi/src/translation_engine.py'nin fallback client'ı için
# (asıl çeviri claude CLI ile ücretsiz gider — openai sadece o yoksa devreye girer).

WORKDIR /app
COPY . .

# Bilgi bankası image içinde; LATO_GIT_PUSH=1 ise bot başlangıçta token'la taze klon alır
# LATO_CRON=1: günlük bülten/WP/finansal/rakip cron'ları bot sürecinin İÇİNDE çalışır
ENV LATO_REPO_DIR=/app \
    LATO_GIT_PUSH=1 \
    LATO_CRON=1 \
    TZ=Asia/Bangkok \
    PYTHONUNBUFFERED=1

# Gerekli env'ler (Railway Variables):
#   TELEGRAM_BOT_TOKEN        — @BotFather
#   CLAUDE_CODE_OAUTH_TOKEN   — PC'de `claude setup-token` çıktısı (abonelik = ücretsiz Sonnet 5)
#   GITHUB_TOKEN              — kayıtların push-back'i için (Contents: RW, sadece bu repo)
CMD ["python3", "telegram-bot/lato_telegram_bot.py"]
